<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:letterSpacing="-0.02"
                android:text="Engine"
                android:textColor="@color/accent_warm"
                android:textSize="36sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/transition_spinner"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginTop="-30dp"
                android:indeterminateTint="@color/accent_warm"
                android:visibility="gone" />

            <!-- Status indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_mode_pill"
                    android:backgroundTint="@color/accent_warm" />

                <TextView
                    android:id="@+id/bit_perfect_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:fontFamily="@font/space_grotesk"
                    android:letterSpacing="0.08"
                    android:text="AUTO ROUTING ENABLED"
                    android:textColor="@color/accent_warm"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Route selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.18"
                android:text="PLAYBACK MODE"
                android:textColor="@color/outline_dark"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Cards Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp">

            <!-- Bit-Perfect -->
            <androidx.cardview.widget.CardView
                android:id="@+id/route_bitperfect_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/route_bitperfect_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="Bit-Perfect Mode"
                            android:textColor="@color/text_primary_soft"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Clean, unprocessed, matched sample rate playback (avoids resamplers)"
                            android:textColor="@color/text_secondary_soft"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/route_bitperfect_indicator"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_mode_pill"
                        android:backgroundTint="@color/accent_warm" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DSP Mode -->
            <androidx.cardview.widget.CardView
                android:id="@+id/route_dsp_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/route_dsp_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="DSP Mode"
                            android:textColor="@color/text_primary_soft"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Flexible processing with float support and software enhancements"
                            android:textColor="@color/text_secondary_soft"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/route_dsp_indicator"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_mode_pill"
                        android:backgroundTint="@color/accent_lavender_light" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Pipeline Node View -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp">
            
            <LinearLayout
                android:id="@+id/pipeline_node_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_mode_pill"
                android:backgroundTint="@color/card_inset"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:paddingHorizontal="12dp"
                android:layout_marginTop="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Source → Decoder" android:textColor="@color/accent_warm" android:fontFamily="@font/space_grotesk" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/node_dsp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" → DSP" android:textColor="@color/accent_lavender" android:fontFamily="@font/space_grotesk" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" → AudioTrack → DAC" android:textColor="@color/accent_mint" android:fontFamily="@font/space_grotesk" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Output Info Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="16dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">
                
                    <LinearLayout
                        android:id="@+id/panel_output_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="18dp">
                        <TextView android:id="@+id/text_source_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary_soft" android:fontFamily="@font/inter" android:textStyle="bold" android:textSize="13sp" />
                        <TextView android:id="@+id/text_output_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent_lavender" android:fontFamily="@font/inter" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="4dp" />
                        <TextView android:id="@+id/text_mode_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary_soft" android:fontFamily="@font/inter" android:textSize="12sp" android:layout_marginTop="4dp" />
                        <TextView android:id="@+id/text_status_match" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent_mint" android:fontFamily="@font/space_grotesk" android:textStyle="bold" android:textSize="11sp" android:layout_marginTop="6dp" />
                    </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Settings Validation Hint -->
        <TextView
            android:id="@+id/text_dsp_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DSP disabled in Bit-Perfect Mode"
            android:gravity="center"
            android:textColor="@color/accent_warm"
            android:fontFamily="@font/inter"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

        <!-- EQ Section -->
        <LinearLayout
            android:id="@+id/eq_section_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk"
                        android:letterSpacing="0.18"
                        android:text="ADVANCED EQUALIZER"
                        android:textColor="@color/accent_lavender"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Launch Modal Button -->
                    <LinearLayout
                        android:id="@+id/btn_open_eq_modal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_mode_pill"
                        android:backgroundTint="@color/accent_lavender_xlight"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_manage"
                            app:tint="@color/accent_lavender" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.06"
                            android:text="OPEN 10-BAND EQ"
                            android:textColor="@color/accent_lavender"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Hardware section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.18"
                android:text="DETECTED HARDWARE"
                android:textColor="@color/outline_dark"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Hardware card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_mode_pill"
                            android:backgroundTint="@color/card_inset">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_manage"
                                app:tint="@color/accent_warm" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/hardware_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="No DAC Connected"
                                android:textColor="@color/text_primary_soft"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/hardware_status_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Connect a compatible USB DAC."
                                android:textColor="@color/text_secondary_soft"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ID row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_mode_pill"
                        android:backgroundTint="@color/card_inset"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/space_grotesk"
                                android:letterSpacing="0.12"
                                android:text="VENDOR"
                                android:textColor="@color/outline_dark"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/vendor_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="--"
                                android:textColor="@color/text_primary_soft"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/space_grotesk"
                                android:letterSpacing="0.12"
                                android:text="PRODUCT"
                                android:textColor="@color/outline_dark"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/product_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="--"
                                android:textColor="@color/text_primary_soft"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/space_grotesk"
                                android:letterSpacing="0.12"
                                android:text="ACCESS"
                                android:textColor="@color/outline_dark"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/hardware_permission_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:text="--"
                                android:textColor="@color/text_primary_soft"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Grant access button — only visible when permission needed -->
                    <LinearLayout
                        android:id="@+id/btn_grant_usb_access"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_mode_pill"
                        android:backgroundTint="@color/accent_mint_light"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_manage"
                            app:tint="@color/accent_mint_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.06"
                            android:text="GRANT USB ACCESS"
                            android:textColor="@color/accent_mint_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
