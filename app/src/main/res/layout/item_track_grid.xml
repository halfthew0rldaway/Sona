<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/card_inset"
        app:cardElevation="2dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp">
            
            <ImageView
                android:id="@+id/item_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/track_number"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/accent_warm"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:maxLines="1"
        android:text="Track Title"
        android:textColor="@color/text_primary_soft"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/item_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="@font/space_grotesk"
        android:gravity="center"
        android:maxLines="1"
        android:text="Artist"
        android:textColor="@color/text_secondary_soft"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/item_duration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/jetbrains_mono"
        android:gravity="center"
        android:text="0:00"
        android:textColor="@color/outline_dark"
        android:textSize="10sp" />

</LinearLayout>
