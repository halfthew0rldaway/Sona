<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:letterSpacing="-0.04"
            android:text="ENGINE"
            android:textColor="@color/on_surface"
            android:textSize="52sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.16"
            android:text="AUDIO CONFIGURATION / INTERFACE CONTROL"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_panel_card_low"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_secondary" />

            <TextView
                android:id="@+id/bit_perfect_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.1"
                android:text="AUTO ROUTING ENABLED"
                android:textColor="@color/secondary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.18"
                android:text="ROUTE SELECTION"
                android:textColor="@color/outline"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_surface"
                android:gravity="center"
                android:text="i"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/route_auto_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_route_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/route_auto_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="Auto (USB Preferred)"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Automatically detects and routes audio to high-fidelity USB interfaces when connected."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp" />
            </LinearLayout>

            <View
                android:id="@+id/route_auto_indicator"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_route_indicator" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:id="@+id/route_usb_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_route_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/route_usb_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="USB Only (Strict Bit-Perfect)"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Bypasses system mixers entirely. Direct hardware communication for uncolored audio reproduction."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_chip_secondary"
                        android:fontFamily="@font/space_grotesk"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="VERIFIED LOW JITTER"
                        android:textColor="@color/on_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:id="@+id/route_usb_indicator"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_route_indicator" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="-2dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_primary_button"
                android:fontFamily="@font/space_grotesk"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="RECOMMENDED"
                android:textColor="@color/on_primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/route_android_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_route_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/route_android_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="System Only"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Routes audio through the OS default mixer. Recommended for general browsing."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp" />
            </LinearLayout>

            <View
                android:id="@+id/route_android_indicator"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_route_indicator" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_panel_card_low"
            android:orientation="vertical"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel_card"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_surface">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_manage"
                            app:tint="@color/primary_container" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="DETECTED HARDWARE"
                            android:textColor="@color/outline"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hardware_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter"
                            android:text="No DAC Connected"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hardware_status_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Connect a compatible USB DAC to unlock direct playback."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="VENDOR"
                            android:textColor="@color/outline_variant"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/vendor_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/space_grotesk"
                            android:text="--"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="PRODUCT ID"
                            android:textColor="@color/outline_variant"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/product_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/space_grotesk"
                            android:text="--"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_panel_slot"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk"
                        android:letterSpacing="0.16"
                        android:text="SUPPORTED FORMATS"
                        android:textColor="@color/primary_container"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_surface"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="PCM 44.1kHz"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_chip_surface"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="PCM 192kHz"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_chip_surface"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="PCM 384kHz"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_primary"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="PCM 768kHz"
                            android:textColor="@color/primary"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_chip_secondary"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="DSD512 (Native)"
                            android:textColor="@color/on_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/space_grotesk"
                        android:letterSpacing="0.12"
                        android:text="INTERFACE STATUS"
                        android:textColor="@color/outline"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hardware_permission_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk"
                        android:text="WAITING FOR HARDWARE"
                        android:textColor="@color/on_surface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="124dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_panel_card"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:padding="10dp">

            <View
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card_high" />

            <View
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card_high" />

            <View
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card_high" />

            <View
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card_high" />

            <View
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button" />

            <View
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel_card_high" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_secondary_button"
            android:gravity="center"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp"
            android:text="Route changes apply immediately. Connect a DAC and start playback to verify the active path."
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
