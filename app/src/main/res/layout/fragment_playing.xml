<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:background="@drawable/bg_panel_card_high"
            android:padding="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_album_art" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="28dp"
                android:background="@drawable/bg_glass_chip"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.12"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:text="MASTER QUALITY AUTHENTICATED"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.12"
            android:text="CURRENT PATH"
            android:textColor="@color/secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/current_path_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono"
            android:text="IDLE"
            android:textColor="@color/primary_container"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/current_path_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono"
            android:text="STBY"
            android:textColor="@color/on_surface_variant"
            android:textSize="40sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/badge_bit_perfect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_badge_bit_perfect"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/on_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.08"
                android:text="VERIFIED BIT-PERFECT"
                android:textColor="@color/on_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/inter"
            android:letterSpacing="-0.03"
            android:text="No Master Loaded"
            android:textColor="@color/on_surface"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/track_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose a WAV file in Browser to begin playback."
            android:textColor="@color/on_surface_variant"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:alpha="0.25"
            android:background="@color/outline_variant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_circle_surface">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_folder"
                            app:tint="@color/on_surface_variant" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="SOURCE FILE"
                            android:textColor="@color/outline"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/source_file_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="NONE"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="18dp"
                    android:text="›"
                    android:textColor="@color/primary_container"
                    android:textSize="28sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_circle_surface">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_manage"
                            app:tint="@color/primary_container" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="PROCESSING"
                            android:textColor="@color/outline"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/backend_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="NO ACTIVE BACKEND"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="18dp"
                    android:text="›"
                    android:textColor="@color/primary_container"
                    android:textSize="28sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_circle_surface_active">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_playing"
                            app:tint="@color/primary_container" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.12"
                            android:text="OUTPUT DAC"
                            android:textColor="@color/primary_container"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/output_device"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="PHONE OUTPUT"
                            android:textColor="@color/on_surface"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="74dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="54dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="42dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="58dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="46dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_primary" />

            <View
                android:layout_width="6dp"
                android:layout_height="22dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_surface" />

            <View
                android:layout_width="6dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_chip_surface" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="26dp"
            android:alpha="0.25"
            android:background="@color/outline_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jetbrains_mono"
                android:text="00:00"
                android:textColor="@color/outline"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/playback_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.08"
                android:text="STANDBY"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jetbrains_mono"
                android:gravity="end"
                android:text="--:--"
                android:textColor="@color/outline"
                android:textSize="16sp" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/playback_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:progress="65"
            app:indicatorColor="@color/primary_container"
            app:trackColor="@color/surface_container_lowest"
            app:trackCornerRadius="6dp"
            app:trackThickness="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:alpha="0.5"
                android:background="@drawable/bg_secondary_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/on_surface_variant" />

            <ImageButton
                android:id="@+id/btn_stop"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_secondary_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:src="@drawable/ic_stop"
                app:tint="@color/on_surface" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_primary_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/on_primary" />

            <ImageButton
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:alpha="0.5"
                android:background="@drawable/bg_secondary_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/on_surface_variant" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
